<svg>
  <defs>
    <link rel="stylesheet" href="styles.css" />
  </defs>

  <rect id="background" />
  <image id="teto" href="teto.png">
    <!-- Portrait slides in from the right and settles into place on every wake;
         clock + stats are already on screen. Resting x is 75 (see styles.css);
         it starts ~95px to the right and slides left. A light fade rides along
         so the leading edge looks clean. Driven via teto.animate("enable"). -->
    <animate attributeName="x"       from="170" to="75" begin="enable" dur="0.7" easing="ease-out" final="restore" />
    <animate attributeName="opacity" from="0"   to="1"  begin="enable" dur="0.5" easing="ease-out" final="restore" />
  </image>
 
  <!-- Smooth fade: 1px-wide rects from x=75 to x=295 with linear opacity -->
  <rect class="teto_fade" x="75" y="0" width="1" height="300" fill="black" opacity="1.000"/>
  <rect class="teto_fade" x="76" y="0" width="1" height="300" fill="black" opacity="0.995"/>
