  <rect class="teto_fade" x="284" y="0" width="1" height="300" fill="black" opacity="0.050"/>
  <rect class="teto_fade" x="285" y="0" width="1" height="300" fill="black" opacity="0.046"/>
  <rect class="teto_fade" x="286" y="0" width="1" height="300" fill="black" opacity="0.041"/>
  <rect class="teto_fade" x="287" y="0" width="1" height="300" fill="black" opacity="0.037"/>
