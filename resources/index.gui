  <rect id="battery_shell" rx="3" ry="3" />
  <rect id="battery_fill"  rx="2" ry="2" />
  <rect id="battery_bump"  rx="2" ry="2" />

  <text id="date_top">--- --</text>
  <text id="date_day">---</text>

  <!-- Time: 4 image elements, one per digit, hrefs swapped in JS.
       Wrapped in a group so they slide in from the left + fade on each wake. -->
  <g id="timeGroup" transform="translate(0,0)">
    <animate          attributeName="opacity"   from="0"     to="1"   begin="enable" dur="0.45" easing="ease-out" final="restore" />
    <animateTransform attributeType="translate"  from="-14,0" to="0,0" begin="enable" dur="0.45" easing="ease-out" final="restore" />
    <image id="h_tens" href="digits/0.png" />
    <image id="h_ones" href="digits/0.png" />
    <image id="m_tens" href="digits/0.png" />
    <image id="m_ones" href="digits/0.png" />
  </g>

  <!-- Metrics -->
  <image id="hr_icon"    href="fonts/heart.png" />
  <text  id="hr_val">000</text>

  <image id="steps_icon" href="fonts/steps.png" />
  <text  id="steps_val">000000</text>

  <image id="cal_icon"   href="fonts/fire.png" />
  <text  id="cal_val">00000</text>
</svg>
